{
  "Request": {
    "Path": {
      "Matchers": [
        {
          "Name": "WildcardMatcher",
          "Pattern": "*"
        }
      ]
    },
    "Methods": [
      "GET"
    ],
    "Headers": [
      {
        "Name": "Host",
        "Matchers": [
          {
            "Name": "ExactMatcher",
            "Pattern": "test-mock-1.mock.internal"
          }
        ]
      }
    ]
  },
  "Response": {
    "StatusCode": 200,
    "Headers": {
      "Content-Type": "text/plain"
    },
    "Body": "hello from test-mock-1.mock.internal on port 8085"
  }
}
